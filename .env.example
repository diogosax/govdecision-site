# =============================================================================
# GovDecision site — environment configuration
#
# Copy to `.env.local` for local development, or set these in the Vercel
# project (Production / Preview). Nothing here is required to run a dev build:
# with no provider configured, the contact API falls back to a safe console
# mode that logs a sanitized lead and never sends anything.
# =============================================================================

# -----------------------------------------------------------------------------
# Contact routing (SITE-004, SITE-005)
# -----------------------------------------------------------------------------
# How contact-form leads are delivered:
#   ses      — transactional email via AWS SES v2 (recommended for production)
#   resend   — transactional email via the Resend HTTP API
#   webhook  — signed POST of the lead payload to CONTACT_WEBHOOK_URL
#   console  — log a sanitized payload only (safe local/dev default)
# If unset (or invalid) in production, the API returns a friendly error and
# delivers nothing — it never silently drops a lead without signalling.

# Recommended production provider
CONTACT_DELIVERY_PROVIDER=ses

# --- Option A: AWS SES (recommended for production) --------------------------
# Required when CONTACT_DELIVERY_PROVIDER=ses.
#
# GovDecision's SES is configured in AWS Oregon. The SES region resolves in
# this order: AWS_SES_REGION -> AWS_REGION -> us-west-2 (default). It never
# defaults to us-east-1.
AWS_REGION=us-west-2
AWS_SES_REGION=us-west-2
# Credentials for an IAM principal scoped to SES sending only (ses:SendEmail /
# ses:SendRawEmail). The AWS SDK reads these from the environment.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional. When set, it is attached to the SES send request; when empty it is
# omitted entirely.
AWS_SES_CONFIGURATION_SET=

# --- Option B: Resend --------------------------------------------------------
# Required when CONTACT_DELIVERY_PROVIDER=resend.
RESEND_API_KEY=

# --- Option C: Webhook -------------------------------------------------------
# Required when CONTACT_DELIVERY_PROVIDER=webhook.
CONTACT_WEBHOOK_URL=
# Optional shared secret. When set, each request includes an
# `X-GovDecision-Signature: sha256=<hmac>` header computed over the raw JSON
# body so the receiver can verify authenticity.
CONTACT_WEBHOOK_SECRET=

# --- Shared contact routing (used by the ses + resend email providers) -------
# Inbox that receives lead notifications.
CONTACT_TO_EMAIL=contact@govdecision.com
# Verified sender. For SES this address (or its domain) must be verified in the
# Oregon SES region. For Resend it must be on a verified domain.
CONTACT_FROM_EMAIL=GovDecision <no-reply@govdecision.com>
# Reply-to used when the lead's work email is not valid for reply.
CONTACT_REPLY_TO_EMAIL=contact@govdecision.com

# -----------------------------------------------------------------------------
# Public URLs (exposed to the browser; safe production defaults are baked in)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://app.govdecision.com
NEXT_PUBLIC_SITE_URL=https://www.govdecision.com
